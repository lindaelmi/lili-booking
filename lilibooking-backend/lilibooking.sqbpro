-- ALTER TABLE hotels ADD COLUMN images TEXT;

-- 2. Mettre à jour avec des images uniques par hôtel (via picsum)
UPDATE hotels SET images = 
    '[&quot;https://picsum.photos/id/' || (id * 10 + 1) || '/800/600&quot;, ' ||
    '&quot;https://picsum.photos/id/' || (id * 10 + 2) || '/800/600&quot;, ' ||
    '&quot;https://picsum.photos/id/' || (id * 10 + 3) || '/800/600&quot;]';</sql><current_tab id="0"/></tab_sql></sqlb_project>
